#read in data
Library <- read.csv("Combined No Zeroes.csv", header=TRUE)
#download vegan to run an nMDS plot
library(vegan)
library(dplyr)
#struggling with the PCA, will try an nMDS using Euclidean distance
#we first need to make a dataframe with only the abundance values for each sample
FTIR <- Library[3:1727]
head(FTIR)
#plot the community data - this will give you a plot of points but it needs to be categorized to be meaningful
FTIR.mds <- metaMDS(comm = FTIR, distance = "euclidean", k=2, trace = FALSE, autotransform = FALSE, try=20, trymax=20, engine=NULL)
plot(FTIR.mds$points)
#check the stress
FTIR.mds$stress
