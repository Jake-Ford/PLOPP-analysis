ON_YP <- rbind(98,69,46,21,24,31,8,20,26,41,19,28,40,71)
ON_WS <- rbind(26,113,229,510,35,102,73,67)
Sup_YP <- rbind(24,4,14,12,11,9,22,21)
Sup_WS <- rbind(13,8,13,1,59,11,9,18,37,24)
Fish<-matrix(1,40)
Fish[1:14]<- ON_YP
Fish[15:22]<- ON_WS
Fish[23:30]<- Sup_YP
Fish[31:40]<- Sup_WS
